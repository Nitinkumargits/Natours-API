    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.12.4",
    "nodemon": "^2.0.22",
    "parcel": "^2.0.1",
    "parcel-bundler": "^1.12.3",
    "prettier": "^2.8.8"
